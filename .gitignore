# Dependencies
node_modules/

# Environment variables (NEVER commit these)
.env
.env.local
.env.production
.env.staging
*.env

# Build output
dist/
build/

# Uploaded files (user-generated content)
backend/uploads/*
!backend/uploads/.gitkeep

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# OS files
.DS_Store
.DS_Store?
Thumbs.db
ehthumbs.db
Desktop.ini

# IDE / Editors
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swp
*.swo
*~

# Package manager locks (keep package-lock.json, ignore others)
yarn.lock
pnpm-lock.yaml

# Coverage & Testing
coverage/
.nyc_output/

# Misc
*.tgz
.cache/
.parcel-cache/
.vercel/
.render/
