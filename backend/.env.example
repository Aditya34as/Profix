# MongoDB connection string (required) — same URI you paste into MongoDB Compass (New Connection).
# Local MongoDB: mongodb://127.0.0.1:27017/profix
# Atlas: mongodb+srv://user:pass@cluster.mongodb.net/profix?retryWrites=true&w=majority
MONGODB_URI=<add your mongodb url>

# Server port
PORT=5000

# JWT secret (change this in production!)
JWT_SECRET=your_jwt_secret_key_here

# Admin key for approving shops
ADMIN_KEY=your_admin_key_here
